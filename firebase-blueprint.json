{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with role and agency affiliation",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["SUPER_ADMIN", "AGENCY", "RESELLER"] },
        "agencyId": { "type": "string", "description": "ID of the agency this user belongs to" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Agency": {
      "title": "Agency Tenant",
      "description": "An agency tenant (node) in the multi-tenant system",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string", "description": "Unique subdomain slug" },
        "domain": { "type": "string", "description": "Optional custom domain" },
        "ownerId": { "type": "string", "description": "UID of the agency owner" },
        "status": { "type": "string", "enum": ["ACTIVE", "SUSPENDED", "PENDING"] },
        "theme": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "ownerId", "status"]
    },
    "Product": {
      "title": "Product",
      "description": "A product offered by an agency",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "basePrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "status": { "type": "string" },
        "type": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "supplier": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "resellerId": { "type": "string" },
        "status": { "type": "string" },
        "totalCost": { "type": "number" },
        "externalOrderId": { "type": "string" },
        "target": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Setting": {
      "title": "Agency Setting",
      "description": "General settings or supplier connections for an agency",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "status": { "type": "string" },
        "supplierName": { "type": "string" },
        "apiKey": { "type": "string" },
        "secretKey": { "type": "string" }
      }
    },
    "Transaction": {
      "title": "Ledger Transaction",
      "description": "A balance transaction in the agency ledger",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "DiscountCode": {
      "title": "Discount Code",
      "description": "A promotional discount code for customers",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["PERCENTAGE", "FIXED", "FREE_SHIPPING"] },
        "value": { "type": "number" },
        "minPurchase": { "type": "number" },
        "maxDiscount": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ACTIVE", "INACTIVE"] },
        "usageLimit": { "type": "number" },
        "usageCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "type", "value", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/agencies/{agencyId}": {
      "schema": "Agency",
      "description": "Agency tenant documents"
    },
    "/agencies/{agencyId}/products/{productId}": {
      "schema": "Product",
      "description": "Agency-specific products"
    },
    "/agencies/{agencyId}/orders/{orderId}": {
      "schema": "Order",
      "description": "Agency-specific orders"
    },
    "/agencies/{agencyId}/settings/{settingId}": {
      "schema": "Setting",
      "description": "Agency settings and connections"
    },
    "/agencies/{agencyId}/transactions/{txId}": {
      "schema": "Transaction",
      "description": "Agency ledger transactions"
    },
    "/agencies/{agencyId}/discounts/{discountId}": {
      "schema": "DiscountCode",
      "description": "Promotional discount codes"
    },
    "/agencies/{agencyId}/wallets/{userId}": {
      "schema": {
        "title": "Wallet",
        "description": "Reseller wallet balance",
        "type": "object",
        "properties": {
          "balance": { "type": "number" },
          "frozenBalance": { "type": "number" },
          "currency": { "type": "string" }
        }
      },
      "description": "Agency wallets"
    }
  }
}
