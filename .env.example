# =========================================================
# NexusCore Enterprise Production Environment Template
# White-Label Top Up & Coin SaaS Infrastructure
# =========================================================

# =========================================================
# APPLICATION
# =========================================================
NODE_ENV=production
PORT=3000
APP_NAME=NexusCore
APP_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com

# =========================================================
# FRONTEND
# =========================================================
VITE_APP_ENV=production
VITE_API_URL=https://api.yourdomain.com
VITE_APP_NAME=NexusCore
VITE_ENABLE_ANALYTICS=true

# =========================================================
# DATABASE (POSTGRESQL)
# =========================================================
DATABASE_URL=postgresql://postgres:CHANGE_THIS_PASSWORD@localhost:5432/nexuscore?schema=public
DIRECT_URL=postgresql://postgres:CHANGE_THIS_PASSWORD@localhost:5432/nexuscore?schema=public

# =========================================================
# REDIS
# =========================================================
REDIS_URL=redis://default:CHANGE_THIS_REDIS_PASSWORD@localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# =========================================================
# SECURITY
# =========================================================
JWT_SECRET=CHANGE_THIS_TO_64_CHARACTER_RANDOM_SECRET_KEY
SESSION_SECRET=CHANGE_THIS_TO_ANOTHER_64_CHARACTER_SECRET
ENCRYPTION_KEY=CHANGE_THIS_TO_32_BYTE_ENCRYPTION_KEY

# =========================================================
# AUTH
# =========================================================
BCRYPT_ROUNDS=12
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# =========================================================
# RATE LIMITING
# =========================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUEST=100

# =========================================================
# CORS
# =========================================================
CORS_ORIGIN=https://yourdomain.com

# =========================================================
# PAYMENT GATEWAYS
# =========================================================

# MIDTRANS
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_MERCHANT_ID=your_midtrans_merchant_id
MIDTRANS_IS_PRODUCTION=true

# XENDIT
XENDIT_SECRET_KEY=your_xendit_secret_key
XENDIT_CALLBACK_TOKEN=your_xendit_callback_token

# DUITKU
DUITKU_MERCHANT_CODE=your_duitku_merchant_code
DUITKU_MERCHANT_KEY=your_duitku_merchant_key
DUITKU_IS_PRODUCTION=true

# DIGIFLAZZ
DIGIFLAZZ_USERNAME=your_digiflazz_username
DIGIFLAZZ_SECRET=your_digiflazz_secret_key

# =========================================================
# WEBHOOK SECURITY
# =========================================================
WEBHOOK_SECRET=CHANGE_THIS_WEBHOOK_SECRET
ENABLE_SIGNATURE_VALIDATION=true
ENABLE_IDEMPOTENCY=true

# =========================================================
# GOOGLE / AI
# =========================================================
GEMINI_API_KEY=your_gemini_api_key

# =========================================================
# SENTRY / OBSERVABILITY
# =========================================================
SENTRY_DSN=
VITE_SENTRY_DSN=

# =========================================================
# LOGGING
# =========================================================
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# =========================================================
# QUEUE SYSTEM
# =========================================================
QUEUE_CONCURRENCY=5
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY=5000

# =========================================================
# CACHE
# =========================================================
CACHE_TTL=3600

# =========================================================
# FILE STORAGE
# =========================================================
UPLOAD_PROVIDER=local
UPLOAD_MAX_SIZE=10485760

# =========================================================
# EMAIL
# =========================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.com

# =========================================================
# DOCKER / DEPLOYMENT
# =========================================================
DOCKER_ENV=production
ENABLE_SWAGGER=false

# =========================================================
# MONITORING
# =========================================================
ENABLE_HEALTHCHECK=true
HEALTHCHECK_PATH=/health

# =========================================================
# FEATURE FLAGS
# =========================================================
ENABLE_REGISTER=true
ENABLE_RESELLER_SYSTEM=true
ENABLE_COIN_SYSTEM=true
ENABLE_REFERRAL_SYSTEM=true

# =========================================================
# KUBERNETES
# =========================================================
K8S_NAMESPACE=nexuscore-production

# =========================================================
# CLOUD STORAGE (OPTIONAL)
# =========================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# =========================================================
# FIREBASE (OPTIONAL)
# =========================================================
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# =========================================================
# SOCKET / REALTIME
# =========================================================
SOCKET_CORS_ORIGIN=https://yourdomain.com

# =========================================================
# CRON JOBS
# =========================================================
ENABLE_CRON=true

# =========================================================
# INTERNAL SERVICES
# =========================================================
INTERNAL_API_SECRET=CHANGE_THIS_INTERNAL_SECRET

# =========================================================
# PRODUCTION SAFETY
# =========================================================
DISABLE_DEBUG_LOGS=true
TRUST_PROXY=true
SECURE_COOKIES=true
