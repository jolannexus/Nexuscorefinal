# Application Environment
NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/nexuscore?schema=public

REDIS_URL=redis://host.docker.internal:6379

JWT_SECRET=supersecretjwt
SESSION_SECRET=supersecretsession
ENCRYPTION_KEY=12345678901234567890123456789012

# Database Settings
DATABASE_URL=postgresql://user:password@localhost:5432/nexuscore?schema=public&sslmode=prefer
DIRECT_URL=postgresql://user:password@localhost:5432/nexuscore?schema=public&sslmode=prefer # Used for Prisma migrations
REDIS_URL=redis://localhost:6379/0

# Security & Authentication
JWT_SECRET=super_secure_random_string_min_32_characters
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Third-Party Integrations (Payment Gateways)
MIDTRANS_SERVER_KEY=your_midtrans_server_key
MIDTRANS_MERCHANT_ID=your_midtrans_merchant_id
MIDTRANS_CLIENT_KEY=your_midtrans_client_key
MIDTRANS_IS_PRODUCTION=false

XENDIT_SECRET_KEY=your_xendit_secret_key
XENDIT_CALLBACK_TOKEN=your_xendit_callback_token

DUITKU_MERCHANT_CODE=your_duitku_merchant_code
DUITKU_MERCHANT_KEY=your_duitku_merchant_key
DUITKU_IS_PRODUCTION=false

DIGIFLAZZ_SECRET=your_digiflazz_secret_key
DIGIFLAZZ_USERNAME=your_digiflazz_username

# Google / AI
GEMINI_API_KEY=your_gemini_api_key

# Sentry Error Tracking (Optional in development, highly recommended in production)
SENTRY_DSN=
VITE_SENTRY_DSN=

VITE_APP_ENV=development
VITE_API_URL=http://localhost:3000
