rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Helper Primitives (Phase 3)
    // -------------------------------------------------------------------------
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      return (request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid))) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : null;
    }
    
    function isSuperAdmin() {
      let data = getUserData();
      return data != null && data.role == 'SUPER_ADMIN';
    }

    function isAgencyOwner(agencyId) {
      return isSignedIn() && (get(/databases/$(database)/documents/agencies/$(agencyId)).data.ownerId == request.auth.uid);
    }

    function belongsToAgency(agencyId) {
      let data = getUserData();
      return data != null && (data.agencyId == agencyId || data.role == 'SUPER_ADMIN');
    }

    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
    }

    function isAgencyRole(agencyId) {
       let data = getUserData();
       return data != null && data.agencyId == agencyId && data.role == 'AGENCY';
    }

    function isSuperAdminOrAgency(agencyId) {
       return isSuperAdmin() || isAgencyRole(agencyId);
    }

    // -------------------------------------------------------------------------
    // Validation Blueprints (Phase 2 & 4.5)
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['SUPER_ADMIN', 'AGENCY', 'RESELLER'] &&
             (!data.keys().contains('agencyId') || data.agencyId is string);
    }

    function isValidAgency(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.slug is string && data.slug.size() <= 50 &&
             data.ownerId is string && data.ownerId == request.auth.uid &&
             data.status in ['ACTIVE', 'SUSPENDED', 'PENDING'];
    }

    function isValidOrder(data) {
      return data.productId is string && 
             data.resellerId is string &&
             data.status is string &&
             data.totalCost is number &&
             data.createdAt == request.time;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.basePrice is number &&
             data.sellingPrice is number;
    }

    // -------------------------------------------------------------------------
    // Default Deny
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Announcements & Tickets (System Level)
    // -------------------------------------------------------------------------
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /tickets/{ticketId} {
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      match /messages/{messageId} {
        allow read: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/tickets/$(ticketId)).data.userId == request.auth.uid);
        allow create: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/tickets/$(ticketId)).data.userId == request.auth.uid);
      }
    }

    // -------------------------------------------------------------------------
    // Users Collection
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isSuperAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                    (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'agencyId', 'role']));
    }

    // -------------------------------------------------------------------------
    // Agencies Collection (Multi-Tenant Root)
    // -------------------------------------------------------------------------
    match /agencies/{agencyId} {
      allow get, list: if true; // Public branding resolution & tenant lookup
      allow create: if isSignedIn() && isValidAgency(incoming());
      allow update: if belongsToAgency(agencyId);

      // --- Agency Sub-Resources (Master Gate Pattern) ---
      
      match /products/{productId} {
        allow read: if true; 
        allow write: if belongsToAgency(agencyId) && isValidProduct(incoming());
      }

      match /orders/{orderId} {
        allow read: if belongsToAgency(agencyId) || (resource != null && resource.data.resellerId == request.auth.uid);
        allow create: if isSignedIn() && isValidOrder(incoming()) && exists(/databases/$(database)/documents/agencies/$(agencyId));
        allow update: if belongsToAgency(agencyId);
      }

      match /settings/{settingId} {
        allow read, write: if isSuperAdminOrAgency(agencyId);
      }

      match /discounts/{discountId} {
        allow read: if true;
        allow write: if isSuperAdminOrAgency(agencyId);
      }

      match /resellers/{resellerId} {
        allow read: if isSuperAdminOrAgency(agencyId) || isOwner(resellerId);
        allow write: if isSuperAdminOrAgency(agencyId);
      }

      match /wallets/{userId} {
        allow read: if isSuperAdminOrAgency(agencyId) || isOwner(userId);
        allow create: if isSuperAdminOrAgency(agencyId) || (isOwner(userId) && incoming().balance == 0);
        allow update: if isSuperAdminOrAgency(agencyId) || 
                         (isOwner(userId) && 
                          incoming().balance <= existing().balance && // Resellers can only decrease available balance
                          incoming().frozenBalance >= existing().frozenBalance && // Resellers can only increase frozen balance
                          (incoming().balance + incoming().frozenBalance) == (existing().balance + existing().frozenBalance)); // The sum must be exact (money is only moved to frozen)
        allow write: if isSuperAdminOrAgency(agencyId);
      }

      match /transactions/{txId} {
        allow read: if isSuperAdminOrAgency(agencyId) || (resource != null && resource.data.resellerId == request.auth.uid);
        allow update, delete: if isSuperAdminOrAgency(agencyId);
        // Reseller can CREATE a transaction if it's for their own wallet (e.g. freezing funds or requesting deposit)
        allow create: if isSuperAdminOrAgency(agencyId) || 
                         (belongsToAgency(agencyId) && 
                          incoming().resellerId == request.auth.uid);
      }

      match /supplier_swaps/{swapId} {
        allow read: if belongsToAgency(agencyId);
        allow create: if isSignedIn() && exists(/databases/$(database)/documents/agencies/$(agencyId));
      }
    }
  }
}
